# Integration test environment — copy to .env.test and fill in real values.
# .env.test is gitignored.
#
# These settings override config.yaml for integration test runs.
# LLM must be reachable when running: uv run pytest test/integration/

LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=your-model-name
LLM_API_KEY=none

# Dummy iTop credentials — real iTop is NOT used (mocked via httpx transport)
ITOP_USER=dummy
ITOP_PWD=dummy
