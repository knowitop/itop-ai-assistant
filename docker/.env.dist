# App configuration
LOG_LEVEL=DEBUG

# Shared secret for webhook authentication (recommended).
# When set, iTop must send this value in the X-Auth-Token header of every
# webhook call. When empty, /webhook accepts unauthenticated requests.
WEBHOOK_TOKEN=

# Shared secret for the /api admin endpoints (X-Admin-Token header).
# When empty, the admin API accepts unauthenticated requests.
ADMIN_TOKEN=

# Directory with prompt overrides: <PROMPTS_DIR>/enrichment/<prompt_name>.md
# shadows the packaged default of the same name. Leave empty to use defaults.
#PROMPTS_DIR=

REDIS_URL=redis://localhost:6379

ITOP_URL=http://itop/webservices/rest.php
ITOP_USER=
ITOP_PWD=
ITOP_TOKEN=

# LLM Configuration (OpenAI-compatible endpoint)
# Examples:
#   LM Studio (local):    LLM_BASE_URL=http://localhost:1234/v1, LLM_API_KEY=lm-studio
#   LiteLLM Proxy:        LLM_BASE_URL=http://litellm:4000/v1,   LLM_API_KEY=any-string
#   OpenAI directly:      LLM_BASE_URL=https://api.openai.com/v1, LLM_API_KEY=sk-...
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=qwen/qwen3.5-9b
LLM_API_KEY=lm-studio

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=