# Everything here is OPTIONAL: the assistant starts with an empty .env and
# can be fully configured at runtime through the setup API (/api/setup, see
# README "Quick start"). Env values act as defaults; runtime overrides made
# through the API are stored in Redis and take priority.

# --- Bootstrap (env-only, need a restart to change) ---
REDIS_URL=redis://redis:6379
LOG_LEVEL=INFO
# Directory with prompt overrides: <PROMPTS_DIR>/enrichment/<prompt_name>.md
# shadows the packaged default of the same name. Leave empty to use defaults.
#PROMPTS_DIR=

# --- Security (also editable via PUT /api/setup/security) ---
# Shared secret for webhook authentication (recommended). When set, iTop must
# send this value in the X-Auth-Token header of every webhook call.
# When empty, /webhook accepts unauthenticated requests.
WEBHOOK_TOKEN=
# Shared secret for the /api admin endpoints (X-Admin-Token header).
# When empty, the admin API accepts unauthenticated requests (first-run mode).
ADMIN_TOKEN=

# --- iTop connection (also editable via PUT /api/setup/itop) ---
ITOP_URL=http://itop/webservices/rest.php
ITOP_USER=
ITOP_PWD=
ITOP_TOKEN=

# --- LLM (also editable via PUT /api/setup/llm) ---
# OpenAI-compatible endpoint. Examples:
#   LM Studio (local):    LLM_BASE_URL=http://localhost:1234/v1, LLM_API_KEY=lm-studio
#   LiteLLM Proxy:        LLM_BASE_URL=http://litellm:4000/v1,   LLM_API_KEY=any-string
#   OpenAI directly:      LLM_BASE_URL=https://api.openai.com/v1, LLM_API_KEY=sk-...
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=
LLM_API_KEY=

# --- Observability (optional) ---
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
