# App configuration
LOG_LEVEL=DEBUG

REDIS_URL=redis://localhost:6379

ITOP_URL=http://itop/webservices/rest.php
ITOP_USER=
ITOP_PWD=
ITOP_TOKEN=

# LLM Configuration (OpenAI-compatible endpoint)
# Examples:
#   LM Studio (local):    LLM_BASE_URL=http://localhost:1234/v1, LLM_API_KEY=lm-studio
#   LiteLLM Proxy:        LLM_BASE_URL=http://litellm:4000/v1,   LLM_API_KEY=any-string
#   OpenAI directly:      LLM_BASE_URL=https://api.openai.com/v1, LLM_API_KEY=sk-...
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=qwen/qwen3.5-9b
LLM_API_KEY=lm-studio

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=